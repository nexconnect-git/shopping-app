# ── Django ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
DJANGO_ENV=local
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOW_CREDENTIALS=True
PUBLIC_BACKEND_URL=https://yourdomain.com
API_PUBLIC_CACHE_TTL_SECONDS=120
API_REFERENCE_CACHE_TTL_SECONDS=300
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7
ENABLE_DJANGO_RQ_DASHBOARD=False

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=nc_shopping_app
DB_USER=postgres
DB_PASSWORD=strongpassword
DB_HOST=db
DB_PORT=5432

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Email (e.g. SendGrid / Mailgun SMTP) ─────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
EMAIL_USE_TLS=True
EMAIL_FROM_NAME=Nextou
EMAIL_FROM_ADDRESS=no-reply@nextou.in
DEFAULT_FROM_EMAIL=no-reply@nextou.in
BRAND_NAME=Nextou
BRAND_TAGLINE=Fast. Fresh. Delivered. ⚡
SUPPORT_EMAIL=support@nextou.in
SUPPORT_PHONE=+91 80 1234 5678
SUPPORT_HOURS=Mon - Sun: 7AM - 11PM
FRONTEND_URL=https://yourdomain.com
CUSTOMER_APP_URL=https://yourdomain.com
VENDOR_APP_URL=https://vendor.yourdomain.com
ADMIN_PANEL_URL=https://admin.yourdomain.com
HELP_URL=https://yourdomain.com/help
FAQ_URL=https://yourdomain.com/help/faq
SUPPORT_URL=https://yourdomain.com/help
ADMIN_VENDOR_REVIEW_EMAIL=vendor-review@example.com
WELCOME_COUPON_CODE=NEXTOU25
OTP_EXPIRY_MINUTES=10
EMAIL_VERIFICATION_EXPIRY_MINUTES=15

# ── Firebase FCM ─────────────────────────────────────────────────────────────
# Path inside the container to the service account JSON.
# Mount the file as a secret or bake it into a secrets volume.
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase_service_account.json

# ── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
# IMPORTANT: If the secret contains $ characters, escape them as $$ (e.g. $zjp → $$zjp)
# Docker Compose treats $x as variable substitution in .env files
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Google Maps JavaScript/Places/Routes API key for Angular apps.
# Keep this in environment/runtime config; do not commit a real key.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Google Cloud Map ID required for Advanced Markers. Leave blank to use legacy markers.
GOOGLE_MAPS_MAP_ID=your-google-maps-map-id

# ── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxxx@oXXXXX.ingest.sentry.io/XXXXX
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Object Storage (S3 / Cloudflare R2) ──────────────────────────────────────
USE_S3=false
FILE_UPLOAD_MAX_SIZE=10485760
FILE_UPLOAD_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,application/pdf
AWS_ACCESS_KEY_ID=REPLACE_WITH_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_SECRET_ACCESS_KEY
AWS_STORAGE_BUCKET_NAME=REPLACE_WITH_BUCKET_NAME
# For Cloudflare R2: https://<account_id>.r2.cloudflarestorage.com
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=ap-southeast-2
AWS_LOCATION=media
# Public custom domain for media CDN (e.g. media.nextou.in)
AWS_S3_CUSTOM_DOMAIN=
