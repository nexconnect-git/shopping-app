# Production Environment Variables Example
# Copy this file to .env and adjust the values before deploying to EC2.

# --- Django Core Settings ---
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_FOR_PRODUCTION
DEBUG=False
ENABLE_DJANGO_RQ_DASHBOARD=False

# Comma-separated list of allowed hostnames (e.g., example.com,www.example.com,SERVER_IP)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# CORS domains that can access the API. Replace * with specific domains in strict production.
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOW_CREDENTIALS=True

# --- PostgreSQL Database Setup ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=nc_shopping_app
DB_USER=postgres
DB_PASSWORD=YOUR_SECURE_DB_PASSWORD
DB_HOST=db
DB_PORT=5432

# --- Redis Setup ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Email Notifications ---
# Set EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend for production
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=YOUR_EMAIL_API_KEY
EMAIL_USE_TLS=True
EMAIL_FROM_NAME=Nextou
EMAIL_FROM_ADDRESS=no-reply@nextou.in
DEFAULT_FROM_EMAIL=no-reply@nextou.in
BRAND_NAME=Nextou
BRAND_TAGLINE=Fast. Fresh. Delivered. ⚡
SUPPORT_EMAIL=support@nextou.in
SUPPORT_PHONE=+91 80 1234 5678
SUPPORT_HOURS=Mon - Sun: 7AM - 11PM
FRONTEND_URL=https://yourdomain.com
CUSTOMER_APP_URL=https://yourdomain.com
VENDOR_APP_URL=https://vendor.yourdomain.com
ADMIN_PANEL_URL=https://admin.yourdomain.com
HELP_URL=https://yourdomain.com/help
FAQ_URL=https://yourdomain.com/help/faq
SUPPORT_URL=https://yourdomain.com/help
ADMIN_VENDOR_REVIEW_EMAIL=vendor-review@example.com
WELCOME_COUPON_CODE=NEXTOU25
OTP_EXPIRY_MINUTES=10
EMAIL_VERIFICATION_EXPIRY_MINUTES=15

# --- Google Maps ---
# Used by Angular apps through generated runtime-config.js.
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
# Required for Google Advanced Markers. Leave blank to fall back to legacy markers.
GOOGLE_MAPS_MAP_ID=YOUR_GOOGLE_MAPS_MAP_ID

# --- Firebase Cloud Messaging (FCM) ---
FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase_service_account.json

# --- Auth Hardening ---
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7
AUTH_REFRESH_COOKIE_SECURE=True
AUTH_REFRESH_COOKIE_SAMESITE=Lax

# --- Machine-learning Recommendation Microservice ---
RECOMMENDATION_SERVICE_URL=http://recommendation:8010
RECOMMENDATION_SERVICE_ENABLED=True
RECOMMENDATION_SERVICE_TIMEOUT_SECONDS=1.5
RECOMMENDER_MODEL_BACKEND=sklearn_hybrid
RECOMMENDER_TRAIN_INTERVAL_SECONDS=3600
